   "source": [
    "from dotenv import load_dotenv\n",
    "import os\n",
    "from openai import OpenAI\n",
    "\n",
    "load_dotenv()\n",
    "\n",
    "api_key = os.getenv(\"OPENAI_API_KEY\")\n",
    "\n",
    "if not api_key:\n",
    "    raise ValueError(\"Please create a new .env file and add your OpenAI API key.\")\n",
    "    \n",
    "client = OpenAI(api_key=api_key)\n"
   ]
  }
